# ========================================
#   WASA BOT - Variables de Entorno
# ========================================

# --- BOT DISCORD ---
DISCORD_TOKEN=tu_token_aqui
DISCORD_CLIENT_ID=tu_client_id_aqui
DISCORD_CLIENT_SECRET=tu_client_secret_aqui

# --- BASE DE DATOS ---
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/wasabot?retryWrites=true&w=majority

# --- API & DASHBOARD ---
API_PORT=3000
API_SECRET_KEY=una_clave_secreta_super_larga_y_aleatoria_aqui

# --- JWT ---
JWT_SECRET=otro_secreto_jwt_muy_largo_y_seguro
JWT_EXPIRES_IN=7d

# --- DISCORD OAUTH2 ---
DISCORD_REDIRECT_URI=http://localhost:3000/auth/callback
# En producción: https://tudominio.com/auth/callback

# --- DASHBOARD ---
DASHBOARD_URL=http://localhost:5500
# En producción: https://tuusuario.github.io/wasa-dashboard

# --- CONFIGURACIÓN GENERAL ---
NODE_ENV=development
BOT_PREFIX=!
DEFAULT_LANGUAGE=es
LOG_LEVEL=info

# --- GUILD PRINCIPAL (para comandos de desarrollo) ---
GUILD_ID=tu_guild_id_aqui

# --- CANAL DE LOGS DEL BOT ---
ERROR_LOG_CHANNEL=id_canal_logs_errores
AUDIT_LOG_CHANNEL=id_canal_logs_auditoria

# --- NOTIFICACIONES DM (tu ID de Discord para recibir alertas de nuevos DMs) ---
OWNER_ID=tu_id_de_usuario_de_discord
